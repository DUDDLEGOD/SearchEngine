{
  "name": "searchengine",
  "module": "index.ts",
  "scripts": {
    "dev": "bun run index.ts",
    "start": "bun run index.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage --coverage-reporter=lcov",
    "check:coverage": "node scripts/check-coverage.mjs coverage/lcov.info 85",
    "ci": "bun run typecheck && bun run test:coverage && bun run check:coverage",
    "typecheck": "bunx tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "private": true,
  "type": "module",
  "dependencies": {
    "natural": "^8.1.1",
    "p-limit": "^7.3.0",
    "stopword": "^3.1.5",
    "zod": "^4.3.6"
  }
}
